{
  "name": "pi-web-agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun run --cwd apps/server dev",
    "dev:server:watch": "bun run --cwd apps/server dev:watch",
    "dev:web": "bun run --cwd apps/web dev",
    "start": "bun run --cwd apps/server start",
    "check": "bun run --cwd packages/protocol check && bun run --cwd apps/server check && bun run --cwd apps/web check && bun scripts/assert-workflow-skills.ts",
    "ui:harness": "bun scripts/ui-harness.ts",
    "ui:manual": "bun scripts/ui-harness.ts --scenario manual --headed --keep",
    "test:web-perf": "bun scripts/ui-harness.ts --scenario all"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "^1.59.1",
    "typescript": "^5.9.2"
  }
}
