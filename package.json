{
  "name": "pi-web-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "bakery": "./scripts/bakery-cli.ts"
  },
  "files": [
    "apps/server/package.json",
    "apps/server/src",
    "apps/server/tsconfig.json",
    "apps/web/index.html",
    "apps/web/package.json",
    "apps/web/public",
    "apps/web/src",
    "apps/web/tsconfig.app.json",
    "apps/web/tsconfig.json",
    "apps/web/tsconfig.node.json",
    "apps/web/vite.config.ts",
    "docs",
    "packages/protocol/package.json",
    "packages/protocol/src",
    "packages/protocol/tsconfig.json",
    "README.md",
    "scripts/bakery-cli-core.ts",
    "scripts/bakery-cli.ts",
    "scripts/install-bakery-package.ts"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:server:up && bun run dev:web",
    "dev:lan": "PI_WEB_HOST=0.0.0.0 bun run dev:server:restart && bun run dev:web:lan",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:server:up": "bun scripts/dev-server-manager.ts up",
    "dev:server:restart": "bun scripts/dev-server-manager.ts restart",
    "dev:server:down": "bun scripts/dev-server-manager.ts down",
    "dev:server:logs": "bun scripts/dev-server-manager.ts logs",
    "dev:server:status": "bun scripts/dev-server-manager.ts status",
    "doctor": "bun scripts/doctor.ts",
    "dev:server:lan": "PI_WEB_HOST=0.0.0.0 bun run --cwd apps/server dev",
    "dev:server:watch": "bun run --cwd apps/server dev:watch",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:web:lan": "bun run --cwd apps/web dev:lan",
    "bakery": "bun scripts/bakery-cli.ts",
    "postinstall": "bun scripts/install-bakery-package.ts",
    "start": "bun run --cwd apps/server start",
    "check": "bun run --cwd packages/protocol check && bun run --cwd apps/server check && bun run --cwd apps/web check && bun scripts/assert-workflow-skills.ts",
    "ui:harness": "bun scripts/ui-harness.ts",
    "ui:manual": "bun scripts/ui-harness.ts --scenario manual --headed --keep",
    "test:web-perf": "bun scripts/ui-harness.ts --scenario all",
    "report:iteration": "bun scripts/report-iteration.ts",
    "project:notes": "bun scripts/project-notes.ts",
    "artifact:upload": "bun scripts/upload-artifact.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@earendil-works/pi-ai": "^0.74.1",
    "@earendil-works/pi-coding-agent": "^0.74.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fastify": "^5.6.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typebox": "^1.1.33",
    "vite": "^8.0.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "ansi-to-html": "^0.7.2",
    "playwright": "^1.59.1",
    "typescript": "^5.9.2"
  }
}
